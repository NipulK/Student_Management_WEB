<link rel="stylesheet" href="/dashboard.css">

<div class="card">
  <div class="profile-header">
    <h2><%= @student[:name] %></h2>
    <div class="profile-actions">
      <a href="/edit/<%= @student[:_id] %>" class="edit-btn">Edit Profile</a>
      <a href="/" class="back-btn">Back to Dashboard</a>
    </div>
  </div>

  <div class="profile-container">
    <div class="profile-section">
      <h3>📋 Basic Information</h3>
      <div class="info-row">
        <label>Full Name:</label>
        <span><%= @student[:name] %></span>
      </div>
      <div class="info-row">
        <label>Age:</label>
        <span><%= @student[:age] %> years old</span>
      </div>
      <div class="info-row">
        <label>Date Added:</label>
        <span><%= @student[:created_at] ? @student[:created_at].strftime("%B %d, %Y") : "N/A" %></span>
      </div>
    </div>

    <div class="profile-section">
      <h3>📧 Contact Information</h3>
      <div class="info-row">
        <label>Email:</label>
        <span><%= @student[:email] || "Not provided" %></span>
      </div>
      <div class="info-row">
        <label>Mobile:</label>
        <span><%= @student[:mobile] %></span>
      </div>
      <div class="info-row">
        <label>Address:</label>
        <span><%= @student[:address] %></span>
      </div>
    </div>

    <div class="profile-section">
      <h3>🏫 School Information</h3>
      <div class="info-row">
        <label>School Name:</label>
        <span><%= @student[:school] %></span>
      </div>
      <div class="info-row">
        <label>Grade/Class:</label>
        <span><%= @student[:grade] || "Not specified" %></span>
      </div>
      <div class="info-row">
        <label>GPA/Marks:</label>
        <span><%= @student[:gpa] || "Not entered" %></span>
      </div>
    </div>

    <div class="profile-section">
      <h3>👨‍👩‍👧 Guardian Information</h3>
      <div class="info-row">
        <label>Guardian Name:</label>
        <span><%= @student[:guardian] || "Not provided" %></span>
      </div>
      <div class="info-row">
        <label>Guardian Phone:</label>
        <span><%= @student[:guardian_phone] || "Not provided" %></span>
      </div>
      <div class="info-row">
        <label>Guardian Address:</label>
        <span><%= @student[:guardian_address] || "Not provided" %></span>
      </div>
    </div>

    <div class="profile-section">
      <h3>🆔 Identification</h3>
      <div class="info-row">
        <label>NIC Number:</label>
        <span><%= @student[:nic] || "Not provided" %></span>
      </div>
      <div class="info-row">
        <label>Student ID:</label>
        <span><code><%= @student[:_id] %></code></span>
      </div>
    </div>

    <div class="profile-actions-bottom">
      <a href="/edit/<%= @student[:_id] %>" class="edit-btn">Edit Student</a>
      <a href="/delete/<%= @student[:_id] %>" class="delete-btn" onclick="return confirm('Are you sure you want to delete this student?')">Delete Student</a>
      <a href="/" class="back-btn">Back to Dashboard</a>
    </div>
  </div>
</div>

<style>
  .profile-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    padding-bottom: 15px;
    border-bottom: 2px solid #ddd;
  }

  .profile-header h2 {
    margin: 0;
    font-size: 28px;
    color: #333;
  }

  .profile-header .profile-actions {
    display: flex;
    gap: 10px;
  }

  .profile-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .profile-section {
    background: #f9f9f9;
    padding: 15px;
    border-radius: 8px;
    border-left: 4px solid #007bff;
  }

  .profile-section h3 {
    margin-top: 0;
    margin-bottom: 15px;
    color: #333;
    font-size: 16px;
  }

  .info-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid #ddd;
  }

  .info-row label {
    font-weight: bold;
    color: #555;
  }

  .info-row span {
    color: #333;
    word-break: break-word;
  }

  .info-row code {
    background: #eee;
    padding: 2px 6px;
    border-radius: 3px;
    font-size: 12px;
  }

  .profile-actions-bottom {
    grid-column: 1 / -1;
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 2px solid #ddd;
  }

  @media (max-width: 768px) {
    .profile-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .profile-header .profile-actions {
      width: 100%;
      margin-top: 10px;
    }

    .profile-container {
      grid-template-columns: 1fr;
    }

    .info-row {
      flex-direction: column;
      gap: 5px;
    }
  }
</style>
