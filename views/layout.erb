<!DOCTYPE html>
<html>
<head>
  <title>Student System</title>
  <link rel="stylesheet" href="/dashboard.css">
  <meta name="viewport" content="width=device-width, initial-scale=1">
</head>

<body>

<% unless request.path_info == '/login' %>
<header class="topbar">
  <div class="logo">🎓 Student System</div>

  <div class="user-area">
    <button onclick="toggleTheme()" class="theme-btn">
      🌗 <span>Theme</span>
    </button>
    
    <div class="user-dropdown">
      <button class="user-profile-btn" onclick="toggleUserMenu()">
        <div class="user-avatar">👤</div>
        <div class="user-info">
          <span class="username"><%= session[:user] %></span>
          <span class="user-role">Admin</span>
        </div>
        <span class="dropdown-arrow">▼</span>
      </button>
      
      <div class="dropdown-menu" id="userDropdown">
        <div class="dropdown-header">
          <div class="dropdown-avatar">👤</div>
          <div>
            <div class="dropdown-name"><%= session[:user] %></div>
            <div class="dropdown-email">admin@studentweb.com</div>
          </div>
        </div>
        <div class="dropdown-divider"></div>
        <a href="/" class="dropdown-item">
          <span class="item-icon">🏠</span>
          Dashboard
        </a>
        <a href="/new" class="dropdown-item">
          <span class="item-icon">➕</span>
          Add Student
        </a>
        <div class="dropdown-divider"></div>
        <a href="/logout" class="dropdown-item logout-item">
          <span class="item-icon">🚪</span>
          Logout
        </a>
      </div>
    </div>
  </div>
</header>
<% end %>

<main class="container">
  <%= yield %>
</main>

<footer class="footer">
  © 2026 Student Management System
</footer>

<script>
function toggleTheme(){
  document.body.classList.toggle("light");
  localStorage.setItem("theme", document.body.classList.contains("light") ? "light" : "dark");
}

function toggleUserMenu() {
  const dropdown = document.getElementById('userDropdown');
  dropdown.classList.toggle('show');
}

// Close dropdown when clicking outside
window.onclick = function(event) {
  if (!event.target.closest('.user-dropdown')) {
    const dropdown = document.getElementById('userDropdown');
    if (dropdown && dropdown.classList.contains('show')) {
      dropdown.classList.remove('show');
    }
  }
}

window.onload = () => {
  if(localStorage.getItem("theme") === "light"){
    document.body.classList.add("light");
  }
}
</script>

<style>
/* User Dropdown Styles */
.user-dropdown {
  position: relative;
}

.user-profile-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  background: rgba(99, 102, 241, 0.1);
  border: 1px solid rgba(99, 102, 241, 0.3);
  padding: 8px 14px;
  border-radius: 12px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.user-profile-btn:hover {
  background: rgba(99, 102, 241, 0.2);
  border-color: var(--primary);
}

.user-avatar {
  font-size: 24px;
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary);
  border-radius: 50%;
}

.user-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
}

.username {
  font-weight: 600;
  font-size: 14px;
  color: var(--text);
}

.user-role {
  font-size: 11px;
  color: var(--accent);
  background: rgba(34, 211, 238, 0.15);
  padding: 2px 8px;
  border-radius: 6px;
  margin-top: 2px;
}

.dropdown-arrow {
  font-size: 10px;
  color: var(--text);
  transition: transform 0.3s ease;
}

.user-profile-btn:hover .dropdown-arrow {
  transform: translateY(2px);
}

.dropdown-menu {
  position: absolute;
  top: 60px;
  right: 0;
  background: var(--card);
  border: 1px solid rgba(99, 102, 241, 0.3);
  border-radius: 12px;
  min-width: 240px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
  opacity: 0;
  visibility: hidden;
  transform: translateY(-10px);
  transition: all 0.3s ease;
  z-index: 1000;
}

.dropdown-menu.show {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.dropdown-header {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 16px;
  border-bottom: 1px solid rgba(99, 102, 241, 0.2);
}

.dropdown-avatar {
  font-size: 32px;
  width: 48px;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--primary);
  border-radius: 50%;
}

.dropdown-name {
  font-weight: 600;
  font-size: 15px;
  color: var(--text);
}

.dropdown-email {
  font-size: 12px;
  color: #94a3b8;
}

.dropdown-divider {
  height: 1px;
  background: rgba(99, 102, 241, 0.2);
  margin: 8px 0;
}

.dropdown-item {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  color: var(--text);
  text-decoration: none;
  transition: all 0.2s ease;
  cursor: pointer;
}

.dropdown-item:hover {
  background: rgba(99, 102, 241, 0.15);
}

.item-icon {
  font-size: 18px;
  width: 24px;
  text-align: center;
}

.logout-item:hover {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

/* Responsive */
@media (max-width: 768px) {
  .topbar {
    padding: 0 20px;
    height: 60px;
  }

  .logo {
    font-size: 18px;
  }

  .theme-btn {
    padding: 8px 12px;
    font-size: 12px;
  }

  .user-info {
    display: none;
  }
  
  .dropdown-arrow {
    display: none;
  }

  .user-profile-btn {
    padding: 8px;
  }

  .user-area {
    gap: 12px;
  }
}

@media (max-width: 480px) {
  .theme-btn span {
    display: none;
  }

  .theme-btn {
    padding: 8px;
    width: 40px;
    justify-content: center;
  }
}
</style>

</body>
</html>
