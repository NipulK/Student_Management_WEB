<link rel="stylesheet" href="/forms.css">

<div class="form-container">
  <h2>Edit Student</h2>

  <form action="/update/<%= @student[:_id] %>" method="post">

    <div class="form-row">
      <label>Full Name</label>
      <input type="text" name="name" value="<%= @student[:name] %>" required>
    </div>

    <div class="form-row">
      <label>Age</label>
      <input type="number" name="age" value="<%= @student[:age] %>" required>
    </div>

    <div class="form-row">
      <label>Email</label>
      <input type="email" name="email" value="<%= @student[:email] %>">
    </div>

    <div class="form-row">
      <label>Mobile Number</label>
      <input type="tel" name="mobile" value="<%= @student[:mobile] %>" required>
    </div>

    <div class="form-row">
      <label>Address</label>
      <input type="text" name="address" value="<%= @student[:address] %>" required>
    </div>

    <div class="form-row">
      <label>NIC Number (Optional)</label>
      <input type="text" name="nic" value="<%= @student[:nic] %>">
    </div>

    <div class="form-row">
      <label>School Name</label>
      <input type="text" name="school" value="<%= @student[:school] %>" required>
    </div>

    <div class="form-row">
      <label>Grade/Class</label>
      <input type="text" name="grade" value="<%= @student[:grade] %>" placeholder="e.g., Grade 10">
    </div>

    <div class="form-row">
      <label>GPA / Marks</label>
      <input type="number" name="gpa" value="<%= @student[:gpa] %>" step="0.01" placeholder="e.g., 3.5">
    </div>

    <div class="form-row">
      <label>Guardian Name</label>
      <input type="text" name="guardian" value="<%= @student[:guardian] %>">
    </div>

    <button class="form-btn">Update Student</button>
    <a href="/student/<%= @student[:_id] %>" class="back-btn">Back to Profile</a>
  </form>
</div>
