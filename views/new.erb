<link rel="stylesheet" href="/forms.css">

<div class="form-container">
  <h2>Add Student</h2>

  <form action="/create" method="post">

    <div class="form-row">
      <label>Full Name</label>
      <input type="text" name="name" required>
    </div>

    <div class="form-row">
      <label>Age</label>
      <input type="number" name="age" required>
    </div>

    <div class="form-row">
      <label>Email</label>
      <input type="email" name="email">
    </div>

    <div class="form-row">
      <label>Mobile Number</label>
      <input type="tel" name="mobile" required>
    </div>

    <div class="form-row">
      <label>Address</label>
      <input type="text" name="address" required>
    </div>

    <div class="form-row">
      <label>NIC Number (Optional)</label>
      <input type="text" name="nic">
    </div>

    <div class="form-row">
      <label>School Name</label>
      <input type="text" name="school" required>
    </div>

    <div class="form-row">
      <label>Grade/Class</label>
      <input type="text" name="grade" placeholder="e.g., Grade 10">
    </div>

    <div class="form-row">
      <label>GPA / Marks</label>
      <input type="number" name="gpa" step="0.01" placeholder="e.g., 3.5">
    </div>

    <div class="form-row">
      <label>Guardian Name</label>
      <input type="text" name="guardian">
    </div>

    <button class="form-btn">Save Student</button>
    <a href="/" class="back-btn">Back to Dashboard</a>
  </form>
</div>
